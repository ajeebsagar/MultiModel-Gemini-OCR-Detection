# ⚠️ IMPORTANT: Get NEW API key from AI Studio
# 
# Your current keys don't work because they're from a project
# where the Generative Language API is not enabled.
#
# SOLUTION:
# 1. Go to: https://aistudio.google.com/app/apikey
# 2. Click "Create API key"
# 3. Choose "Create API key in NEW project" (IMPORTANT!)
# 4. Copy the new key
# 5. Paste it below (use SAME key for all three)
#
# Example:
# GEMINI_FLASH_KEY=AIzaSyABC123def456GHI789jkl012MNO345pqr
# GEMINI_PRO_KEY=AIzaSyABC123def456GHI789jkl012MNO345pqr
# GEMINI_LITE_KEY=AIzaSyABC123def456GHI789jkl012MNO345pqr

GEMINI_FLASH_KEY=paste_your_new_key_here
GEMINI_PRO_KEY=paste_your_new_key_here
GEMINI_LITE_KEY=paste_your_new_key_here
